{
  "name": "lab",
  "productName": "LAB",
  "version": "0.1.0",
  "description": "LAB is a local-first engineering project workspace and public page generator.",
  "main": "./out/main/index.js",
  "author": "David <davoafo@gmail.com>",
  "homepage": "https://electron-vite.org",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "typecheck:node": "node_modules\\.bin\\tsc.cmd --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "node_modules\\.bin\\tsc.cmd --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "node_modules\\.bin\\tsc.cmd --noEmit -p tsconfig.node.json --composite false && node_modules\\.bin\\tsc.cmd --noEmit -p tsconfig.web.json --composite false",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "node_modules\\.bin\\tsc.cmd --noEmit -p tsconfig.node.json --composite false && node_modules\\.bin\\tsc.cmd --noEmit -p tsconfig.web.json --composite false && node_modules\\.bin\\electron-vite.cmd build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win portable",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux",
    "release:local": "npm run build && node scripts/build-local-release.mjs"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.3.0",
    "@codemirror/theme-one-dark": "^6.1.2",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@tiptap/extension-link": "^2.11.5",
    "@tiptap/react": "^2.11.5",
    "@tiptap/starter-kit": "^2.11.5",
    "@uiw/react-codemirror": "^4.24.1",
    "archiver": "^7.0.1",
    "better-sqlite3": "^12.8.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dompurify": "^3.2.5",
    "drizzle-orm": "^0.44.2",
    "electron-store": "^10.1.0",
    "gray-matter": "^4.0.3",
    "isomorphic-git": "^1.30.0",
    "jsdom": "^26.1.0",
    "marked": "^14.1.3",
    "mime-types": "^2.1.35",
    "papaparse": "^5.5.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1",
    "ulidx": "^2.4.1",
    "zod": "^3.24.2",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/mime-types": "^2.1.4",
    "@types/node": "^22.19.1",
    "@types/papaparse": "^5.3.16",
    "@types/react": "^18.3.21",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^5.1.1",
    "drizzle-kit": "^0.31.4",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3",
    "vite": "^7.2.6"
  }
}
